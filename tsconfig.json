{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"strict": true,
		"strictNullChecks": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["node", "bun"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
